# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (may contain secrets)
*.tfvars
*.tfvars.json
!*.tfvars.example

# Plan output
*.tfplan
*.tfplan.*

# CLI configuration
.terraformrc
terraform.rc

# Lock info
.terraform.lock.hcl.bak

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
